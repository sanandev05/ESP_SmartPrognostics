@page
@model IndexModel
@{
    ViewData["Title"] = "İdarə paneli";

    var now = DateTime.Now;
    var nowStr = now.ToString("dd.MM.yyyy HH:mm:ss");
    var invariant = System.Globalization.CultureInfo.InvariantCulture;

    // Sensor status determination
    var voltageStatus = (Model.Voltage >= 360.0f && Model.Voltage <= 410.0f) ? "allowable" : (Model.Voltage >= 340.0f && Model.Voltage <= 430.0f) ? "warning" : "dangerous";
    var currentStatus = Model.Current_A <= 13.0f ? "allowable" : Model.Current_A <= 16.0f ? "warning" : "dangerous";
    var tempStatus = Model.Temperature_C <= 70.0f ? "allowable" : Model.Temperature_C <= 85.0f ? "warning" : "dangerous";
    var vibStatus = Model.Vibration_RMS <= 2.8f ? "allowable" : Model.Vibration_RMS <= 4.5f ? "warning" : "dangerous";
    // Count statuses
    var statuses = new[] { voltageStatus, currentStatus, tempStatus, vibStatus };
    int allowCount = statuses.Count(s => s == "allowable");
    int warnCount = statuses.Count(s => s == "warning");
    int dangerCount = statuses.Count(s => s == "dangerous");

    // Overall system status
    bool systemOk = dangerCount == 0;
    string systemStatusClass = dangerCount > 0 ? "danger" : warnCount > 0 ? "warn" : "ok";
    string systemStatusText = dangerCount > 0 ? "SİSTEM TƏHLÜKƏDƏ" : warnCount > 0 ? "SİSTEM NƏZARƏTDƏ" : "SİSTEM NORMALDIR";
    string systemStatusDesc = dangerCount > 0
        ? "Bəzi göstəricilər təhlükəli həddə çatıb. Dərhal müdaxilə tələb olunur."
        : warnCount > 0
            ? "Bəzi göstəricilər xəbərdarlıq zonasındadır. Nəzarət altında saxlayın."
            : "Bütün göstəricilər icazə verilən hədlər daxilindədir.";
}

<section class="dashboard-page" id="dashboardPage"
         data-rul="@Model.RemainingLife.ToString("0.0", invariant)"
         data-health="@Model.Health_Index.ToString("0.0", invariant)"
         data-degradation="@Model.DegradationPercent.ToString("0.0", invariant)"
         data-confidence="@Model.ConfidenceScore.ToString("0.0", invariant)"
         data-voltage="@Model.Voltage.ToString("0.0", invariant)"
         data-current="@Model.Current_A.ToString("0.0", invariant)"
         data-vibration="@Model.Vibration_RMS.ToString("0.00", invariant)"
         data-temperature="@Model.Temperature_C.ToString("0.0", invariant)">

    <!-- ═══ TOP NAVBAR ═══ -->
    <nav class="dash-navbar">
        <div class="nav-left">
            <button class="nav-hamburger" aria-label="Menyu">
                <i class="fa-solid fa-bars"></i>
            </button>
            <span class="nav-title">İdarə paneli</span>
        </div>
        <div class="nav-right">
            <button class="theme-toggle-btn" id="themeToggleBtn" aria-label="Qaranlıq rejim">
                <i class="fa-solid fa-moon"></i>
                <span>Qaranlıq rejim</span>
            </button>
            <button class="nav-icon-btn" aria-label="Bildirişlər">
                <i class="fa-solid fa-bell"></i>
                <span class="nav-badge">1</span>
            </button>
            <button class="nav-icon-btn" aria-label="Təqvim">
                <i class="fa-regular fa-calendar"></i>
            </button>
            <button class="nav-icon-btn" aria-label="Kömək">
                <i class="fa-regular fa-circle-question"></i>
            </button>
            <div class="nav-user">
                <div class="nav-avatar"><i class="fa-solid fa-user" style="font-size:.7rem"></i></div>
                <div class="nav-user-info">
                    <div class="nav-user-name">Admin</div>
                    <div class="nav-user-role">Mühəndis</div>
                </div>
                <i class="fa-solid fa-chevron-down nav-chevron"></i>
            </div>
        </div>
    </nav>

    <div class="dash-container">

        <!-- ═══ INFO STRIP ═══ -->
        <div class="info-strip">
            <div class="info-strip-item">
                <div class="info-strip-label">Vaxt göstəricisi</div>
                <div class="info-strip-value" id="infoDateTime">@nowStr</div>
            </div>
            <div class="info-strip-item">
                <div class="info-strip-label">Proqnoz modeli</div>
                <div class="info-strip-value">@Model.ModelStatus</div>
            </div>
            <div class="info-strip-item">
                <div class="info-strip-label">Nasazlıq göstəricisi</div>
                <div class="info-strip-value">@Model.FaultLabel</div>
            </div>
            <div class="info-strip-item">
                <div class="info-strip-label">Məlumat mənbəyi</div>
                <div class="info-strip-value">Sensor simulyatoru</div>
            </div>
            <div class="info-strip-item">
                <div class="info-strip-label">ISO 10816 həddi</div>
                <div class="info-strip-value">7.1 mm/s</div>
            </div>
        </div>

        <div class="dashboard-main-grid">
            
            <!-- LEFT COLUMN: Main Content -->
            <div class="dashboard-left-col">

                <!-- ═══ SENSOR CARDS ROW ═══ -->
                <div class="sensor-cards-row">

            <!-- Card 1: Gərginlik -->
            <div class="sensor-card" id="sensorVoltage">
                <div class="sensor-card-header">
                    <div class="sensor-card-title">
                        <span class="sensor-num sensor-num-1">1</span>
                        <span class="sensor-card-name">Gərginlik</span>
                        <i class="fa-solid fa-circle-info sensor-card-info-icon"></i>
                    </div>
                    <span class="status-badge badge-@voltageStatus" id="badgeVoltage">@(voltageStatus == "allowable" ? "Normal" : voltageStatus == "warning" ? "Nəzarət" : "Təhlükəli")</span>
                </div>
                <div class="sensor-value-row">
                    <span class="sensor-big-value" id="valVoltage">@Model.Voltage.ToString("0")</span>
                    <span class="sensor-unit">V</span>
                </div>
                <div class="range-bar-container">
                    <div class="range-bar" id="rangeBarVoltage">
                        <div class="range-segment range-segment-red" style="width:20%"></div>
                        <div class="range-segment range-segment-yellow" style="width:20%"></div>
                        <div class="range-segment range-segment-green" style="width:30%"></div>
                        <div class="range-segment range-segment-yellow" style="width:20%"></div>
                        <div class="range-segment range-segment-red" style="width:10%"></div>
                        <div class="range-marker" id="markerVoltage" style="left:40%"></div>
                    </div>
                    <div class="range-labels">
                        <span class="range-label">340</span>
                        <span class="range-label">360</span>
                        <span class="range-label">380</span>
                        <span class="range-label">410</span>
                        <span class="range-label">440</span>
                    </div>
                </div>
                <div class="range-legend">
                    <span class="range-legend-item"><span class="legend-dot legend-dot-green"></span> Normal (380-410 V)</span>
                    <span class="range-legend-item"><span class="legend-dot legend-dot-yellow"></span> Nəzarət (360-380/410-430 V)</span>
                    <span class="range-legend-item"><span class="legend-dot legend-dot-red"></span> Təhlükəli (&lt;360/&gt;430 V)</span>
                </div>
            </div>

            <!-- Card 2: Cərəyan -->
            <div class="sensor-card" id="sensorCurrent">
                <div class="sensor-card-header">
                    <div class="sensor-card-title">
                        <span class="sensor-num sensor-num-2">2</span>
                        <span class="sensor-card-name">Cərəyan</span>
                        <i class="fa-solid fa-circle-info sensor-card-info-icon"></i>
                    </div>
                    <span class="status-badge badge-@currentStatus" id="badgeCurrent">@(currentStatus == "allowable" ? "Normal" : currentStatus == "warning" ? "Nəzarət" : "Təhlükəli")</span>
                </div>
                <div class="sensor-value-row">
                    <span class="sensor-big-value" id="valCurrent">@Model.Current_A.ToString("0.0")</span>
                    <span class="sensor-unit">A</span>
                </div>
                <div class="range-bar-container">
                    <div class="range-bar" id="rangeBarCurrent">
                        <div class="range-segment range-segment-green" style="width:65%"></div>
                        <div class="range-segment range-segment-yellow" style="width:15%"></div>
                        <div class="range-segment range-segment-red" style="width:20%"></div>
                        <div class="range-marker" id="markerCurrent" style="left:69%"></div>
                    </div>
                    <div class="range-labels">
                        <span class="range-label">0</span>
                        <span class="range-label">13</span>
                        <span class="range-label">16</span>
                        <span class="range-label">20</span>
                    </div>
                </div>
                <div class="range-legend">
                    <span class="range-legend-item"><span class="legend-dot legend-dot-green"></span> Normal (≤13 A)</span>
                    <span class="range-legend-item"><span class="legend-dot legend-dot-yellow"></span> Nəzarət (13 - 16 A)</span>
                    <span class="range-legend-item"><span class="legend-dot legend-dot-red"></span> Təhlükəli (&gt;16 A)</span>
                </div>
            </div>

            <!-- Card 3: Temperatur -->
            <div class="sensor-card" id="sensorTemperature">
                <div class="sensor-card-header">
                    <div class="sensor-card-title">
                        <span class="sensor-num sensor-num-3">3</span>
                        <span class="sensor-card-name">Temperatur</span>
                        <i class="fa-solid fa-circle-info sensor-card-info-icon"></i>
                    </div>
                    <span class="status-badge badge-@tempStatus" id="badgeTemp">@(tempStatus == "allowable" ? "Normal" : tempStatus == "warning" ? "Nəzarət" : "Təhlükəli")</span>
                </div>
                <div class="sensor-value-row">
                    <span class="sensor-big-value" id="valTemp">@Model.Temperature_C.ToString("0.0")</span>
                    <span class="sensor-unit">°C</span>
                </div>
                <div class="range-bar-container">
                    <div class="range-bar" id="rangeBarTemp">
                        <div class="range-segment range-segment-green" style="width:70%"></div>
                        <div class="range-segment range-segment-yellow" style="width:15%"></div>
                        <div class="range-segment range-segment-red" style="width:15%"></div>
                        <div class="range-marker" id="markerTemp" style="left:68%"></div>
                    </div>
                    <div class="range-labels">
                        <span class="range-label">0</span>
                        <span class="range-label">70</span>
                        <span class="range-label">85</span>
                        <span class="range-label">100</span>
                    </div>
                </div>
                <div class="range-legend">
                    <span class="range-legend-item"><span class="legend-dot legend-dot-green"></span> Normal (≤70)</span>
                    <span class="range-legend-item"><span class="legend-dot legend-dot-yellow"></span> Nəzarət (70 - 85)</span>
                    <span class="range-legend-item"><span class="legend-dot legend-dot-red"></span> Təhlükəli (&gt;85)</span>
                </div>
            </div>

            <!-- Card 4: Vibrasiya -->
            <div class="sensor-card" id="sensorVibration">
                <div class="sensor-card-header">
                    <div class="sensor-card-title">
                        <span class="sensor-num sensor-num-4">4</span>
                        <span class="sensor-card-name">Vibrasiya (RMS)</span>
                        <i class="fa-solid fa-circle-info sensor-card-info-icon"></i>
                    </div>
                    <span class="status-badge badge-@vibStatus" id="badgeVib">@(vibStatus == "allowable" ? "Normal" : vibStatus == "warning" ? "Nəzarət" : "Təhlükəli")</span>
                </div>
                <div class="sensor-value-row">
                    <span class="sensor-big-value" id="valVib">@Model.Vibration_RMS.ToString("0.00")</span>
                    <span class="sensor-unit">mm/s</span>
                </div>
                <div class="range-bar-container">
                    <div class="range-bar" id="rangeBarVib">
                        <div class="range-segment range-segment-green" style="width:39.4%"></div>
                        <div class="range-segment range-segment-yellow" style="width:23.9%"></div>
                        <div class="range-segment range-segment-red" style="width:36.7%"></div>
                        <div class="range-marker" id="markerVib" style="left:5.9%"></div>
                    </div>
                    <div class="range-labels">
                        <span class="range-label">0</span>
                        <span class="range-label">2.8</span>
                        <span class="range-label">4.5</span>
                        <span class="range-label">7.1</span>
                    </div>
                </div>
                <div class="range-legend">
                    <span class="range-legend-item"><span class="legend-dot legend-dot-green"></span> Normal (≤2.8)</span>
                    <span class="range-legend-item"><span class="legend-dot legend-dot-yellow"></span> Nəzarət (2.8 - 4.5)</span>
                    <span class="range-legend-item"><span class="legend-dot legend-dot-red"></span> Təhlükəli (&gt;4.5)</span>
                </div>
                <div class="sensor-card-footnote">ISO 10816 həddi: 7.1 mm/s</div>
            </div>
        </div>

        <!-- ═══ MIDDLE PANELS ═══ -->
        <div class="middle-panels">

            <!-- RUL Panel -->
            <div class="panel-card rul-panel">
                <div class="panel-title">Qalıq işləmə müddəti (QİM)</div>
                <div class="rul-content">
                    <div class="rul-gauge-wrapper">
                        <canvas id="rulGauge"></canvas>
                        <div class="rul-center-text">
                            <div class="rul-value" id="rulValue">@Model.RemainingLife.ToString("0")</div>
                            <div class="rul-unit">saat</div>
                        </div>
                    </div>
                    <div class="rul-details">
                        <p class="rul-description">Cari göstəricilərə əsasən avadanlığın işləyə biləcəyi təxmini qalıq müddət.</p>
                        <div class="rul-meta-row">
                            <span class="rul-meta-label">Etibarlılıq</span>
                            <span class="rul-meta-value" id="rulConfidence">@Model.ConfidenceScore.ToString("0.0")%</span>
                        </div>
                        <div class="rul-meta-row">
                            <span class="rul-meta-label">Proqnoz üsulu</span>
                            <span class="rul-meta-value">ML.NET LightGBM</span>
                        </div>
                        <div class="rul-meta-row" style="border-bottom:none">
                            <span class="rul-meta-label">Son proqnoz vaxtı</span>
                            <span class="rul-meta-value">@now.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status Panel -->
            <div class="panel-card status-panel">
                <div class="panel-title">Ümumi vəziyyət</div>
                <div class="status-icon-wrapper status-icon-@systemStatusClass" id="statusIcon">
                    @if (systemStatusClass == "ok")
                    {
                        <i class="fa-solid fa-check" style="color:var(--green)"></i>
                    }
                    else if (systemStatusClass == "warn")
                    {
                        <i class="fa-solid fa-exclamation" style="color:var(--orange)"></i>
                    }
                    else
                    {
                        <i class="fa-solid fa-xmark" style="color:var(--red)"></i>
                    }
                </div>
                <h3 class="status-heading" id="statusHeading">@systemStatusText</h3>
                <p class="status-desc" id="statusDesc">@systemStatusDesc</p>
                <div class="status-counts">
                    <div class="status-count-box status-count-box-green">
                        <div class="status-count-label status-count-label-green">Normal</div>
                        <div class="status-count-value status-count-value-green" id="countAllow">@allowCount</div>
                    </div>
                    <div class="status-count-box status-count-box-orange">
                        <div class="status-count-label status-count-label-orange">Nəzarət</div>
                        <div class="status-count-value status-count-value-orange" id="countWarn">@warnCount</div>
                    </div>
                    <div class="status-count-box status-count-box-red">
                        <div class="status-count-label status-count-label-red">Təhlükəli</div>
                        <div class="status-count-value status-count-value-red" id="countDanger">@dangerCount</div>
                    </div>
                </div>
            </div>
        </div>



        <!-- ═══ BOTTOM SECTION ═══ -->
        <div class="bottom-section">

            <!-- Trend Chart -->
            <div class="trend-panel">
                <div class="trend-header">
                    <span class="trend-title">Trend qrafikləri</span>
                    <div class="trend-filters">
                        <button class="trend-filter-btn active" data-range="1h">1 saat</button>
                        <button class="trend-filter-btn" data-range="6h">6 saat</button>
                        <button class="trend-filter-btn" data-range="24h">24 saat</button>
                        <button class="trend-filter-btn" data-range="7d">7 gün</button>
                    </div>
                </div>
                <div class="trend-legend">
                    <span class="trend-legend-item"><span class="trend-legend-line" style="background:#3b82f6"></span> Gərginlik (V)</span>
                    <span class="trend-legend-item"><span class="trend-legend-line" style="background:#8b5cf6"></span> Cərəyan (A)</span>
                    <span class="trend-legend-item"><span class="trend-legend-line" style="background:#f59e0b"></span> Temperatur (°C)</span>
                    <span class="trend-legend-item"><span class="trend-legend-line" style="background:#22c55e"></span> Vibrasiya (mm/s)</span>
                </div>
                <div class="trend-chart-wrapper">
                    <canvas id="trendChart"></canvas>
                </div>
            </div>

            <!-- Alerts Panel -->
            <div class="alerts-panel">
                <div class="alerts-title">Son xəbərdarlıqlar</div>
                <ul class="alert-list" id="alertList">
                    <li class="alert-item">
                        <div class="alert-icon alert-icon-warning"><i class="fa-solid fa-exclamation"></i></div>
                        <div class="alert-content">
                            <div class="alert-text">Temperatur xəbərdarlıq həddinə yaxınlaşır</div>
                            <div class="alert-detail">Cari dəyər: @Model.Temperature_C.ToString("0.0") °C</div>
                        </div>
                        <div class="alert-time" id="alertTime1">@now.ToString("HH:mm:ss")</div>
                    </li>
                    <li class="alert-item">
                        <div class="alert-icon alert-icon-ok"><i class="fa-solid fa-check"></i></div>
                        <div class="alert-content">
                            <div class="alert-text">Vibrasiya normal həddədir</div>
                            <div class="alert-detail">Cari dəyər: @Model.Vibration_RMS.ToString("0.00") mm/s</div>
                        </div>
                        <div class="alert-time" id="alertTime2">@now.AddSeconds(-5).ToString("HH:mm:ss")</div>
                    </li>
                    <li class="alert-item">
                        <div class="alert-icon alert-icon-warning"><i class="fa-solid fa-exclamation"></i></div>
                        <div class="alert-content">
                            <div class="alert-text">Cərəyan xəbərdarlıq həddinə yaxınlaşır</div>
                            <div class="alert-detail">Cari dəyər: @Model.Current_A.ToString("0.0") A</div>
                        </div>
                        <div class="alert-time" id="alertTime3">@now.AddSeconds(-20).ToString("HH:mm:ss")</div>
                    </li>
                </ul>
                <a class="alerts-show-all" href="#">Hamısını göstər <i class="fa-solid fa-arrow-right" style="font-size:.65rem"></i></a>
            </div>
            </div>
            </div>
            
            <!-- RIGHT COLUMN: Sidebar (Controls & Logs) -->
            <div class="dashboard-right-col">
                
                <!-- Texniki Jurnallar Card -->
                <div class="panel-card logs-card">
                    <div class="panel-title" style="margin-bottom:8px">Texniki jurnallar</div>
                    <div class="panel-subtitle" style="font-weight:700; font-size:1.1rem; color:var(--text-primary); margin-bottom:16px">ML mühərrikinin proqnozları</div>
                    <div class="prediction-logs" id="predictionLogs">
                        <!-- Logs loaded dynamically -->
                    </div>
                </div>

                <!-- Giriş Vektoru Card -->
                <div class="panel-card simulator-card">
                    <div class="panel-title" style="margin-bottom:8px">Giriş məlumatları</div>
                    <div class="panel-subtitle" style="font-weight:700; font-size:1.1rem; color:var(--text-primary); margin-bottom:16px">Sensor simulyatoru</div>
                    
                    <form method="get" class="sidebar-form">
                        <div class="sidebar-form-grid">
                            <div class="form-group">
                                <label class="form-label" for="inputCycle">İŞ DÖVRÜ</label>
                                <input class="form-control" type="number" step="1" id="inputCycle" name="Cycle" value="@Model.Cycle.ToString("0", invariant)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="inputVoltage">GƏRGİNLİK, V</label>
                                <input class="form-control" type="number" step="1" id="inputVoltage" name="Voltage" value="@Model.Voltage.ToString("0", invariant)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="inputCurrent">CƏRƏYAN, A</label>
                                <input class="form-control" type="number" step="0.1" id="inputCurrent" name="Current_A" value="@Model.Current_A.ToString("0.0", invariant)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="inputVib">VİBRASİYA (RMS)</label>
                                <input class="form-control" type="number" step="0.01" id="inputVib" name="Vibration_RMS" value="@Model.Vibration_RMS.ToString("0.00", invariant)" />
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="inputTemp">TEMPERATUR, °C</label>
                                <input class="form-control" type="number" step="0.1" id="inputTemp" name="Temperature_C" value="@Model.Temperature_C.ToString("0.0", invariant)" />
                            </div>
                            <div class="form-group form-group-full">
                                <label class="form-label" for="inputHealth">SAĞLAMLIQ İNDEKSİ</label>
                                <input class="form-control" type="number" step="1" id="inputHealth" name="Health_Index" value="@Model.Health_Index.ToString("0", invariant)" />
                            </div>
                        </div>
                        <button type="submit" class="btn-update-prognosis">Proqnozu yenilə</button>
                    </form>
                </div>
                
            </div>
            
        </div>

        <!-- ═══ FOOTER STRIP ═══ -->
        <div class="footer-strip">
            <div class="footer-item">
                <div class="footer-item-label">Avadanlıq</div>
                <div class="footer-item-primary">Mühərrik #1</div>
                <div class="footer-item-secondary">ID: MOT-001</div>
            </div>
            <div class="footer-item">
                <div class="footer-item-label">Yerləşmə</div>
                <div class="footer-item-primary">İstehsalat sahəsi 2</div>
                <div class="footer-item-secondary">Xətt: X-01</div>
            </div>
            <div class="footer-item">
                <div class="footer-item-label">İş rejimi</div>
                <div class="footer-item-primary">Yüklü</div>
                <div class="footer-item-secondary">RPM: 1450</div>
            </div>
            <div class="footer-item">
                <div class="footer-item-label">Son baxış</div>
                <div class="footer-item-primary">15.05.2026</div>
                <div class="footer-item-secondary">18 gün əvvəl</div>
            </div>
            <div class="footer-item">
                <div class="footer-item-label">Növbəti baxış</div>
                <div class="footer-item-primary">15.06.2026</div>
                <div class="footer-item-secondary">13 gün qaldı</div>
            </div>
            <div class="footer-item">
                <div class="footer-item-label">İşləmə müddəti</div>
                <div class="footer-item-primary">5320 saat</div>
                <div class="footer-item-secondary">Ümumi işləmə</div>
            </div>
        </div>

    </div>
</section>
